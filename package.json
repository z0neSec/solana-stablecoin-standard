{
  "name": "solana-stablecoin-standard",
  "version": "0.1.0",
  "description": "Solana Stablecoin Standard — modular SDK with opinionated presets for Token-2022 stablecoins",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:programs": "anchor build",
    "build:sdk": "cd sdk && yarn build",
    "build": "yarn build:programs && yarn build:sdk",
    "test": "anchor test",
    "test:sdk": "cd sdk && yarn test",
    "test:backend": "cd backend && yarn test",
    "lint": "cd sdk && yarn lint",
    "clean": "anchor clean && cd sdk && rm -rf dist"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.9"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "chai": "^4.4.1",
    "mocha": "^10.4.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3",
    "prettier": "^3.2.0"
  }
}
